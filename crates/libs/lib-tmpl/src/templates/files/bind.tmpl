//==============================================================================
// Generated by ozone
//==============================================================================

//==============================================================================
// ACLs
//==============================================================================
{%- if !cfg.bind.acls.is_empty() %}
{%- for acl in cfg.bind.acls %}

// ACL #{{ loop.index0 }} - {{ acl.name }}
acl "{{ acl.name }}" {
{%- for network in acl.networks %}
  {{ network }};
{%- endfor %}
};

{%- endfor %}
{%- endif %}

//==============================================================================
// Views
//==============================================================================
{%- if !views.is_empty() %}
{%- for view in views %}
{% let v = view.view %}
// View #{{ loop.index0 }} - {{ v.name }}
view "{{ v.name }}" {
{%- if !v.acls.is_empty() %}
  match-clients {
{%- for acl_name in v.acls %}
    {{ acl_name }};
{%- endfor %}
  };
{%- endif %}

{%- if v.recursion %}

  recursion yes;
{%- endif %}

{%- if !v.redirect.is_empty() %}

  forwarders {
{%- for forwarder in v.redirect %}
    {{ forwarder }};
{%- endfor %}
  };
{%- endif %}

{%- if !v.redirect_zones.is_empty() %}
{%- for forwarded_zone in v.redirect_zones %}

  zone "{{ forwarded_zone.domain }}" {
    type forward;
    forward only;
    forwarders {
{%- for forwarder in forwarded_zone.networks %}
      {{ forwarder }};
{%- endfor %}
    };
  };
{%- endfor %}
{%- endif %}

{%- if !v.zones.is_empty() %}

  // Forward Zone
{% for zone in v.zones %}
  include "{{ out_dir }}/{{ zone }}.zone.conf";
{%- endfor %}
{%- endif %}

{%- if !view.reverse_zones.is_empty() %}

  // Reverse Zone
{% for rev in view.reverse_zones %}
  include "{{ out_dir }}/rev.{{ rev }}.zone.conf";
{%- endfor %}
{%- endif %}
};
{%- endfor %}
{%- endif %}